<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>PROTEGO | Your Digital Shield</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background-color: #f4f6fb;
    }

    /* HERO */
    .hero {
      background: linear-gradient(135deg, #4e54c8, #8f94fb);
      color: white;
      padding: 140px 20px;
      border-bottom-left-radius: 90px;
      border-bottom-right-radius: 90px;
    }

    /* INFO */
    .section-title {
      font-weight: 700;
      margin-bottom: 40px;
    }

    .info-card {
      background: white;
      border-radius: 18px;
      padding: 30px;
      box-shadow: 0 15px 40px rgba(0,0,0,0.08);
      height: 100%;
    }

    /* CHAT BUTTON */
    .chat-btn {
      position: fixed;
      bottom: 25px;
      right: 25px;
      background: linear-gradient(135deg, #4e54c8, #8f94fb);
      border: none;
      width: 70px;
      height: 70px;
      border-radius: 50%;
      font-size: 28px;
      color: white;
      box-shadow: 0 12px 30px rgba(0,0,0,0.3);
      z-index: 1000;
    }

    /* CHAT BOX */
    .chat-box {
      display: none;
      position: fixed;
      bottom: 110px;
      right: 30px;
      width: 480px;
      height: 650px;
      background: white;
      border-radius: 20px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.35);
      overflow: hidden;
      z-index: 1000;
    }

    .chat-header {
      background: linear-gradient(135deg, #4e54c8, #8f94fb);
      color: white;
      padding: 18px;
      font-weight: 600;
      text-align: center;
      font-size: 18px;
    }

    .chat-body {
      padding: 18px;
      height: 430px;
      overflow-y: auto;
      background-color: #f8f9ff;
    }

    .bot-msg, .user-msg {
      padding: 14px 16px;
      border-radius: 16px;
      margin-bottom: 14px;
      max-width: 78%;
      font-size: 15px;
      line-height: 1.5;
    }

    .bot-msg {
      background: #eef1ff;
    }

    .user-msg {
      background: #d1ffe0;
      margin-left: auto;
    }

    .emergency {
      border: 2px solid #dc3545;
      background: #fff0f0;
      font-weight: 600;
    }

    footer {
      margin-top: 80px;
    }
  </style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-dark bg-dark fixed-top shadow">
  <div class="container">
    <span class="navbar-brand fw-bold">🛡️ PROTEGO</span>
  </div>
</nav>

<!-- HERO -->
<section class="hero text-center">
  <div class="container">
    <h1 class="display-3 fw-bold">PROTEGO</h1>
    <p class="mt-4 fs-5">
      Your AI-powered digital shield for emotional distress,
      domestic violence support, and crisis safety guidance.
    </p>
    <button class="btn btn-light btn-lg mt-5 px-5" onclick="toggleChat()">
      Talk to Protego 🤍
    </button>
  </div>
</section>

<!-- INFO SECTIONS -->
<section class="container my-5">
  <h2 class="text-center section-title">How Protego Helps</h2>
  <div class="row g-4">
    <div class="col-md-4">
      <div class="info-card">
        <h5>🤍 Emotional Support</h5>
        <p>
          Protego listens without judgment and responds with empathy
          when you feel scared, sad, or overwhelmed.
        </p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="info-card">
        <h5>🛡️ Safety Detection</h5>
        <p>
          Advanced AI detects emotional distress, abuse patterns,
          and escalating danger in real time.
        </p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="info-card">
        <h5>🚨 Emergency Guidance</h5>
        <p>
          When danger is detected, Protego immediately shows
          emergency contacts and safety instructions.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="container my-5">
  <h2 class="text-center section-title">When Should You Use Protego?</h2>
  <div class="row g-4">
    <div class="col-md-6">
      <div class="info-card">
        <ul>
          <li>You feel unsafe or threatened</li>
          <li>Someone is hurting you physically or emotionally</li>
          <li>You feel scared to go home</li>
          <li>You need immediate guidance</li>
        </ul>
      </div>
    </div>
    <div class="col-md-6">
      <div class="info-card">
        <p class="fw-semibold text-danger">
          ⚠️ If you are in immediate danger, contact emergency services.
        </p>
        <p>
          Protego is a support tool, not a replacement for law enforcement
          or medical professionals.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- CHAT BUTTON -->
<button class="chat-btn" onclick="toggleChat()">💬</button>

<!-- CHAT BOX -->
<div class="chat-box" id="chatBox">
  <div class="chat-header">Protego Assistant</div>

  <div class="chat-body" id="chatBody">
    <div class="bot-msg">
      Hello 🤍 I’m Protego. You’re safe here. How can I help you today?
    </div>
  </div>

  <div class="p-3 border-top bg-white">
    <div class="input-group">
      <input id="userInput"
             class="form-control form-control-lg"
             placeholder="Type your message..."
      />
      <button class="btn btn-primary btn-lg px-4" onclick="sendMessage()">
        Send
      </button>
    </div>
  </div>
</div>

<!-- FOOTER -->
<footer class="bg-dark text-white text-center py-3">
  <small>© 2026 PROTEGO | AI for Safety & Human Dignity</small>
</footer>

<script>
const chatBox = document.getElementById("chatBox");
const chatBody = document.getElementById("chatBody");
const userInput = document.getElementById("userInput");

function toggleChat() {
  chatBox.style.display = chatBox.style.display === "block" ? "none" : "block";
}

userInput.addEventListener("keypress", function (e) {
  if (e.key === "Enter") sendMessage();
});

async function sendMessage() {
  const text = userInput.value.trim();
  if (!text) return;

  addMessage(text, "user-msg");
  userInput.value = "";

  try {
    const res = await fetch("http://127.0.0.1:8000/chat", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ message: text, country: "India" })
    });

    const data = await res.json();
    const cls = data.risk_level === "emergency"
      ? "bot-msg emergency"
      : "bot-msg";

    addMessage(data.reply, cls);

    if (data.emergency_contacts) {
      let html = "<strong>Emergency Contacts:</strong><ul>";
      for (const [k, v] of Object.entries(data.emergency_contacts)) {
        html += `<li><b>${k}</b>: ${v.number}</li>`;
      }
      html += "</ul>";
      addMessage(html, "bot-msg emergency");
    }

  } catch {
    addMessage("⚠️ Sorry, I’m having trouble connecting right now.", "bot-msg");
  }
}

function addMessage(text, className) {
  const div = document.createElement("div");
  div.className = className;
  div.innerHTML = text;
  chatBody.appendChild(div);
  chatBody.scrollTop = chatBody.scrollHeight;
}
</script>

</body>
</html>
